PORT=5000
DB_CONNECTION_STRING=postgresql://user:password@host:5432/database

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_secure_refresh_token_secret_key_change_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=https://rbac-apps.netlify.app
